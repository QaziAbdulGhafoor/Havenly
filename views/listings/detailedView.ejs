<% layout("../layouts/boilerplate") %>

<body>
  <h2 class="text-center mb-4 mt-2">
    <%= listing.title %>
  </h2>

  <!-- Listing Card -->
  <div class="row justify-content-center">
    <div class="col-md-8 col-lg-6">
      <div class="card detail-card mb-4">
        <img
          src="<%= listing.image.url ? listing.image.url : listing.image %>"
          class="card-img-top"
          alt="listing image"
        />

        <div class="card-body">
          <h5 class="card-title"><%= listing.title %></h5>
          <p class="card-text"><%= listing.description %></p>
        </div>

        <ul class="list-group list-group-flush">
          <li class="list-group-item">
            <b>Country:</b> <%= listing.country %>
          </li>
          <li class="list-group-item">
            <b>Location:</b> <%= listing.location %>
          </li>
          <li class="list-group-item">
            <b>Price:</b> PKR <%= listing.price.toLocaleString("en-PK") %>
          </li>
        </ul>

        <div class="card-body d-flex gap-2">
          <a
            href="/listings/<%= listing._id %>/edit"
            class="btn btn-success"
          >
            Edit
          </a>

          <form
            action="/listings/<%= listing._id %>?_method=DELETE"
            method="POST"
          >
            <button class="btn btn-danger">Delete</button>
          </form>
        </div>

      </div>
    </div>
  </div>

  <!-- Review Form -->
  <div class="row justify-content-center">
    <div class="col-md-8 col-lg-6">
      <form
        action="/listings/<%= listing._id %>/reviews"
        method="POST"
        class="mb-4"
      >
        <div class="mb-3">
          <label for="rating" class="form-label">Rating:</label>
          <input
            type="range"
            id="rating"
            min="1"
            max="5"
            name="review[ratings]"
            class="form-range"
            oninput="this.nextElementSibling.value = this.value"
          />
          <output>3</output>
        </div>

        <div class="mb-3">
          <label for="comment" class="form-label">
            Enter your comment:
          </label>
          <textarea
            name="review[comment]"
            rows="3"
            id="comment"
            class="form-control"
          ></textarea>
        </div>
        <button class="btn btn-success">Add Review</button>
      </form>
    </div>
  </div>

  <!-- Reviews Section -->
  <div class="row justify-content-center">
    <div class="col-md-8 col-lg-6">
      <h4 class="mb-3">All Reviews</h4>

      <div class="row">
        <% if (listing.reviews && listing.reviews.length > 0) { %>
          <% listing.reviews.forEach(function(review) { %>

            <div class="col-md-6 mb-3">
              <div class="card review">
                <div class="card-body">
                  <div class="d-flex justify-content-between">
                    <h5 class="mb-1">Author</h5>
                    <span><%for(let i=1;i<=review.ratings;i++){%>
                      ⭐
                      <% } %>
                    </span>
                  </div>

                  <p class="mt-2 mb-0">
                    <%= review.comment %>
                  </p>
                  <form action="/listings/<%=listing.id%>/reviews/<%=review.id%>?_method=DELETE" method="post"><button class="btn btn-outline-dark mt-1">Delete</button></form>
                  
               </div>
              </div>
            </div>

          <% }) %>
        <% } else { %>
          <p>No reviews yet</p>
        <% } %>
      </div>

    </div>
  </div>
</body>