<% layout("layouts/boilerplate") %>
<h1 id="new-head">Add New Listing</h1>
<form
  class="row g-3 needs-validation"
  novalidate
  method="post"
  action="/listings"
>
  <div class="col-12 mb-1">
    <label for="inputEmail4" class="form-label">Enter Listing Title:</label>
    <input
      type="text"
      class="form-control"
      id="inputEmail4"
      placeholder="Enter a listing name"
      name="listing[title]"
      required
    />
    <div class="valid-feedback">Title Looks good!</div>
    <div class="invalid-feedback">Invalid listing name</div>
  </div>
  <div class="col-8 mb-1">
    <label for="image" class="form-label">Enter Image Link:</label>
    <input
      type="text"
      class="form-control"
      id="image"
      placeholder="Enter a listing name"
      name="listing[image]"
      required
    />
    <div class="valid-feedback">Image Looks good!</div>
    <div class="invalid-feedback">Invalid image link</div>
  </div>
  <div class="col-4 mb-1">
    <label for="inputState" class="form-label">Price:</label>
    <input
      type="number"
      id="inputState"
      class="form-control"
      placeholder="Enter a reasonable price"
      name="listing[price]"
      required
    />
    <div class="valid-feedback">Price Looks good!</div>
    <div class="invalid-feedback">Invalid price</div>
  </div>
  <div class="col-12 mb-1">
    <label for="inputAddress" class="form-label"
      >Enter a Justifying Description:</label
    >
    <textarea
      class="form-control"
      id="inputAddress"
      placeholder="This place is ...."
      name="listing[description]"
      required
    ></textarea>
    <div class="valid-feedback">Description Looks good!</div>
    <div class="invalid-feedback">Invalid description</div>
  </div>
  <div class="col-md-6 mb-1">
    <label for="inputCity" class="form-label">Country:</label>
    <input
      type="text"
      class="form-control"
      placeholder="Enter country name e.g India"
      name="listing[country]"
      required
    />
    <div class="valid-feedback">Country is Valid</div>
    <div class="invalid-feedback">Invalid country name</div>
  </div>
  <div class="col-md-6 mb-1">
    <label for="inputAddress2" class="form-label">Address:</label>
    <input
      type="text"
      class="form-control"
      id="inputAddress2"
      placeholder="detailed location"
      name="listing[location]"
      required
    />
    <div class="valid-feedback">Address Looks good!</div>
    <div class="invalid-feedback">Invalid address</div>
  </div>

  <div class="col-12 mb-2">
    <button type="submit" class="btn btn-success add">Add</button>
  </div>
</form>
